{
  "index_patterns": ["zipkin-*"],
  "template": {
    "settings": {
      "index": {
        "number_of_shards": 1,
        "number_of_replicas": 0,
        "refresh_interval": "5s",
        "codec": "best_compression"
      }
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "traceId": {
          "type": "keyword",
          "index": true
        },
        "spanId": {
          "type": "keyword",
          "index": true
        },
        "parentId": {
          "type": "keyword",
          "index": true
        },
        "operationName": {
          "type": "keyword",
          "index": true
        },
        "serviceName": {
          "type": "keyword",
          "index": true
        },
        "duration": {
          "type": "long"
        },
        "timestamp": {
          "type": "long"
        },
        "tags": {
          "type": "object",
          "properties": {
            "http.method": {
              "type": "keyword"
            },
            "http.url": {
              "type": "keyword"
            },
            "http.status_code": {
              "type": "integer"
            },
            "error": {
              "type": "boolean"
            },
            "component": {
              "type": "keyword"
            },
            "db.type": {
              "type": "keyword"
            },
            "db.statement": {
              "type": "text"
            }
          }
        },
        "process": {
          "type": "object",
          "properties": {
            "serviceName": {
              "type": "keyword"
            },
            "tags": {
              "type": "object"
            }
          }
        },
        "logs": {
          "type": "nested",
          "properties": {
            "timestamp": {
              "type": "long"
            },
            "fields": {
              "type": "object"
            }
          }
        },
        "localEndpoint": {
          "type": "object",
          "properties": {
            "serviceName": {
              "type": "keyword"
            },
            "ipv4": {
              "type": "ip"
            },
            "ipv6": {
              "type": "ip"
            },
            "port": {
              "type": "integer"
            }
          }
        },
        "remoteEndpoint": {
          "type": "object",
          "properties": {
            "serviceName": {
              "type": "keyword"
            },
            "ipv4": {
              "type": "ip"
            },
            "ipv6": {
              "type": "ip"
            },
            "port": {
              "type": "integer"
            }
          }
        },
        "kind": {
          "type": "keyword"
        },
        "shared": {
          "type": "boolean"
        },
        "debug": {
          "type": "boolean"
        }
      }
    }
  },
  "priority": 100,
  "version": 1,
  "_meta": {
    "description": "Template for Zipkin tracing data"
  }
}